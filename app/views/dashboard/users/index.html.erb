<%= render "layouts/header" %>
<div class="row">
  <%= render "layouts/sidebar" %>
  <div class="col-md mt-3 ms-auto col-lg-10 px-md-4">
    <% if notice %>
    <div class="alert alert-success alert-dismissible fade show" role="alert">
      <i class="fas fa-check-circle me-2"></i><%= notice %>
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
    <% end %>

    <% if alert %>
    <div class="alert alert-warning alert-dismissible fade show" role="alert">
      <i class="fas fa-exclamation-triangle me-2"></i><%= alert %>
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
    <% end %>

    <div class="d-flex justify-content-between align-items-center mb-4">
      <div>
        <h2 class="mb-1">
          <i class="fas fa-users text-success me-2"></i>Usuarios del Sistema
        </h2>
        <p class="text-muted mb-0">Administra los usuarios registrados en la plataforma</p>
      </div>
      <%= link_to new_dashboard_user_path, class: "btn btn-success" do %>
        <i class="fas fa-plus me-2"></i>Nuevo Usuario
      <% end %>
    </div>

    <!-- Stats Cards -->
    <div class="row g-3 mb-4">
      <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100 stats-card">
          <div class="card-body">
            <div class="d-flex justify-content-between align-items-center">
              <div>
                <p class="text-muted mb-1 small">Total Usuarios</p>
                <h3 class="mb-0 fw-bold"><%= @users.count %></h3>
              </div>
              <div class="stats-icon stats-icon-primary">
                <i class="fas fa-users fa-2x"></i>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100 stats-card">
          <div class="card-body">
            <div class="d-flex justify-content-between align-items-center">
              <div>
                <p class="text-muted mb-1 small">Superadmins</p>
                <h3 class="mb-0 fw-bold"><%= @users.count(&:super_admin?) %></h3>
              </div>
              <div class="stats-icon stats-icon-warning">
                <i class="fas fa-user-shield fa-2x"></i>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100 stats-card">
          <div class="card-body">
            <div class="d-flex justify-content-between align-items-center">
              <div>
                <p class="text-muted mb-1 small">Último Registro</p>
                <h6 class="mb-0 fw-bold">
                  <%= @users.last&.created_at&.strftime("%d/%m/%Y") || 'N/A' %>
                </h6>
              </div>
              <div class="stats-icon stats-icon-info">
                <i class="fas fa-calendar-plus fa-2x"></i>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Users Table -->
    <div class="card border-0 shadow-sm">
      <div class="card-header bg-white border-0 py-3">
        <div class="d-flex justify-content-between align-items-center">
          <h5 class="mb-0">
            <i class="fas fa-list text-success me-2"></i>Lista de Usuarios
          </h5>
          <div class="input-group input-group-sm" style="width: 250px;">
            <input type="text" class="form-control" placeholder="Buscar usuarios..." id="searchInput">
            <button class="btn btn-outline-secondary" type="button">
              <i class="fas fa-search"></i>
            </button>
          </div>
        </div>
      </div>

      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table table-hover mb-0">
            <thead class="table-light">
              <tr>
                <th scope="col" class="ps-4">ID</th>
                <th scope="col">Nombre</th>
                <th scope="col">Email</th>
                <th scope="col">Rol / Departamento</th>
                <th scope="col">Registrado</th>
                <th scope="col" class="text-center">Acciones</th>
              </tr>
            </thead>
            <tbody>
              <% @users.each do |user| %>
                <tr class="user-item">
                  <td class="ps-4">
                    <div class="user-icon bg-success-subtle text-success rounded me-3">
                      <%= user.id %>
                    </div>
                  </td>
                  <td>
                    <% full_name = [user.name, user.lastname].compact.join(" ") %>
                    <% if full_name.present? %>
                      <span class="fw-bold"><%= full_name %></span>
                    <% else %>
                      <span class="text-muted fst-italic">Sin nombre</span>
                    <% end %>
                  </td>
                  <td>
                    <h6 class="mb-0"><%= user.email %></h6>
                  </td>
                  <td>
                    <% if user.super_admin? %>
                      <span class="badge bg-danger">Superadmin</span>
                    <% else %>
                      <span class="badge bg-secondary"><%= user.department_label %></span>
                    <% end %>
                  </td>
                  <td>
                    <small class="text-muted"><%= user.created_at.strftime("%d/%m/%Y") %></small>
                  </td>
                  <td>
                    <div class="d-flex justify-content-center gap-2">
                      <%= link_to dashboard_user_path(user), class: "btn btn-sm btn-outline-success", title: "Ver" do %>
                        <i class="fas fa-eye"></i>
                      <% end %>
                      <%= link_to edit_dashboard_user_path(user), class: "btn btn-sm btn-outline-warning", title: "Editar" do %>
                        <i class="fas fa-edit"></i>
                      <% end %>
                      <%= button_to dashboard_user_path(user), method: :delete, data: { confirm: '¿Estás seguro de eliminar este usuario?' }, form: { class: 'd-inline' }, class: "btn btn-sm btn-outline-danger", title: "Eliminar" do %>
                        <i class="fas fa-trash"></i>
                      <% end %>
                    </div>
                  </td>
                </tr>
              <% end %>

              <% if @users.empty? %>
                <tr>
                  <td colspan="6" class="text-center py-5">
                    <div class="text-muted">
                      <i class="fas fa-users fa-3x mb-3"></i>
                      <h5>No hay usuarios registrados</h5>
                      <p class="mb-3">Comienza creando el primer usuario</p>
                      <%= link_to new_dashboard_user_path, class: "btn btn-green-deu" do %>
                        <i class="fas fa-plus me-2"></i>Crear Usuario
                      <% end %>
                    </div>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>
