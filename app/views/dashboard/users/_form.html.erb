<%= form_with(model: [:dashboard, user], class: "form-container") do |form| %>
  <% if user.errors.any? %>
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
      <i class="fas fa-exclamation-triangle me-2"></i>
      <h5 class="alert-heading mb-2">
        <%= pluralize(user.errors.count, "error") %> impidieron guardar este usuario:
      </h5>
      <ul class="mb-0">
        <% user.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
  <% end %>

  <div class="card border-0 shadow-sm mb-4">
    <div class="card-header bg-white border-0 py-3">
      <h5 class="mb-0">
        <i class="fas fa-user text-success me-2"></i>Información del Usuario
      </h5>
    </div>
    <div class="card-body">
      <div class="row g-3">
        <!-- Nombre -->
        <div class="col-md-6">
          <div class="form-group">
            <%= form.label :name, "Nombre", class: "form-label fw-bold text-dark mb-2" %>
            <%= form.text_field :name, class: "form-control", placeholder: "Nombre del usuario" %>
          </div>
        </div>

        <!-- Apellido -->
        <div class="col-md-6">
          <div class="form-group">
            <%= form.label :lastname, "Apellido", class: "form-label fw-bold text-dark mb-2" %>
            <%= form.text_field :lastname, class: "form-control", placeholder: "Apellido del usuario" %>
          </div>
        </div>

        <!-- Email -->
        <div class="col-md-6">
          <div class="form-group">
            <%= form.label :email, "Correo Electrónico", class: "form-label fw-bold text-dark mb-2" %>
            <%= form.email_field :email, class: "form-control", placeholder: "usuario@ejemplo.com", required: true %>
          </div>
        </div>

        <!-- Teléfono -->
        <div class="col-md-6">
          <div class="form-group">
            <%= form.label :number_phone, "Teléfono", class: "form-label fw-bold text-dark mb-2" %>
            <%= form.text_field :number_phone, class: "form-control", placeholder: "(0212) 605-0000" %>
          </div>
        </div>

        <!-- Departamento (solo para usuarios no-superadmin) -->
        <% unless user.super_admin? %>
          <div class="col-md-12">
            <div class="form-group">
              <%= form.label :department, "Departamento", class: "form-label fw-bold text-dark mb-2" %>
              <% if current_user&.super_admin? %>
                <%= form.select :department,
                                options_for_select(User.department_options_for_select, user.department),
                                { include_blank: "Seleccione una opción..." },
                                class: "form-select", required: true %>
                <small class="form-text text-muted">Superusuario: puedes asignar cualquier departamento.</small>
              <% else %>
                <%= form.hidden_field :department, value: (user.department || current_user&.department) %>
                <input type="text" class="form-control" value="<%= user.department_label || current_user&.department_label %>" disabled>
                <small class="form-text text-muted">Solo puedes crear/editar usuarios en tu propio departamento.</small>
              <% end %>
            </div>
          </div>
        <% end %>

        <!-- Contraseña -->
        <div class="col-md-6">
          <div class="form-group">
            <%= form.label :password, "Contraseña", class: "form-label fw-bold text-dark mb-2" %>
            <%= form.password_field :password, class: "form-control", placeholder: "Contraseña segura", required: user.new_record? %>
            <small class="form-text text-muted"><%= user.new_record? ? "Mínimo 6 caracteres." : "Dejar en blanco para mantener la actual." %></small>
          </div>
        </div>

        <!-- Confirmar Contraseña -->
        <div class="col-md-6">
          <div class="form-group">
            <%= form.label :password_confirmation, "Confirmar Contraseña", class: "form-label fw-bold text-dark mb-2" %>
            <%= form.password_field :password_confirmation, class: "form-control", placeholder: "Repita la contraseña", required: user.new_record? %>
            <small class="form-text text-muted">Confirme la contraseña ingresada.</small>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="card border-0 shadow-sm">
    <div class="card-body">
      <div class="d-flex justify-content-between align-items-center">
        <%= link_to dashboard_users_path, class: "btn btn-outline-secondary" do %>
          <i class="fas fa-times me-2"></i>Cancelar
        <% end %>
        <%= form.submit class: "btn btn-success btn-lg" %>
      </div>
    </div>
  </div>
<% end %>
