<%= render "layouts/header" %>
<div class="row">
  <%= render "layouts/sidebar" %>
  <div class="col-md mt-3 ms-auto col-lg-10 px-md-4">
    <% if notice %>
      <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="fas fa-check-circle me-2"></i><%= notice %>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
      </div>
    <% end %>

    <% if alert %>
      <div class="alert alert-warning alert-dismissible fade show" role="alert">
        <i class="fas fa-exclamation-triangle me-2"></i><%= alert %>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
      </div>
    <% end %>

    <div class="d-flex justify-content-between align-items-center mb-4">
      <div>
        <h2 class="mb-1">
          <i class="fas fa-calendar-day text-success me-2"></i>Detalles del Evento
        </h2>
        <p class="text-muted mb-0">Información completa del evento</p>
      </div>
      <div class="d-flex gap-2">
        <% if can?(:update, @event) %>
          <%= link_to edit_dashboard_event_path(@event), class: "btn btn-warning" do %>
            <i class="fas fa-edit me-2"></i>Editar
          <% end %>
        <% end %>
        <%= link_to dashboard_events_path, class: "btn btn-outline-secondary" do %>
          <i class="fas fa-arrow-left me-2"></i>Volver al Listado
        <% end %>
      </div>
    </div>

    <nav aria-label="breadcrumb" class="mb-4">
      <ol class="breadcrumb">
        <li class="breadcrumb-item">
          <%= link_to "Dashboard", dashboard_index_path, class: "text-success" %>
        </li>
        <li class="breadcrumb-item">
          <%= link_to "Eventos", dashboard_events_path, class: "text-success" %>
        </li>
        <li class="breadcrumb-item active" aria-current="page">
          <%= truncate(@event.title.presence || "Sin título", length: 30) %>
        </li>
      </ol>
    </nav>

    <div class="row g-4">
      <div class="col-lg-8">
        <div class="card border-0 shadow-sm mb-4">
          <div class="card-header bg-white border-0 py-3">
            <h5 class="mb-0">
              <i class="fas fa-info-circle text-success me-2"></i>Información General
            </h5>
          </div>
          <div class="card-body">
            <div class="row g-3">
              <div class="col-12">
                <div class="detail-item">
                  <label class="detail-label">Título del Evento</label>
                  <div class="detail-value">
                    <h4 class="text-dark mb-0"><%= @event.title.presence || "Sin título" %></h4>
                  </div>
                </div>
              </div>

              <div class="col-md-6">
                <div class="detail-item">
                  <label class="detail-label">Fecha</label>
                  <div class="detail-value">
                    <i class="fas fa-calendar-alt text-muted me-2"></i>
                    <%= @event.day.present? ? l(@event.day, format: "%A, %d de %B de %Y") : "Sin fecha" %>
                  </div>
                </div>
              </div>

              <div class="col-md-6">
                <div class="detail-item">
                  <label class="detail-label">Estado</label>
                  <div class="detail-value">
                    <span class="badge bg-success fs-6">
                      <i class="fas fa-circle me-1" style="font-size: 6px;"></i>
                      Activo
                    </span>
                  </div>
                </div>
              </div>

              <div class="col-12">
                <div class="detail-item">
                  <label class="detail-label">Descripción</label>
                  <div class="detail-value">
                    <% if @event.description&.body&.to_plain_text&.present? %>
                      <div class="trix-content"><%= @event.description %></div>
                    <% else %>
                      <span class="text-muted fst-italic">Sin descripción</span>
                    <% end %>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <div class="card border-0 shadow-sm mb-4">
          <div class="card-header bg-white border-0 py-3">
            <h5 class="mb-0">
              <i class="fas fa-image text-success me-2"></i>Imagen del Evento
            </h5>
          </div>
          <div class="card-body">
            <% if @event.image_event.attached? %>
              <%= image_tag @event.image_event, class: "img-fluid rounded border", style: "max-height: 420px; object-fit: contain;" %>
            <% else %>
              <span class="text-muted fst-italic">Este evento no tiene imagen asociada.</span>
            <% end %>
          </div>
        </div>

        <div class="card border-0 shadow-sm">
          <div class="card-header bg-white border-0 py-3">
            <h5 class="mb-0">
              <i class="fas fa-database text-success me-2"></i>Metadatos
            </h5>
          </div>
          <div class="card-body">
            <div class="row g-3">
              <div class="col-md-4">
                <div class="detail-item">
                  <label class="detail-label">ID</label>
                  <div class="detail-value">
                    <code class="text-muted"><%= @event.id %></code>
                  </div>
                </div>
              </div>

              <div class="col-md-4">
                <div class="detail-item">
                  <label class="detail-label">Creado</label>
                  <div class="detail-value"><%= @event.created_at.strftime("%d/%m/%Y %H:%M") %></div>
                </div>
              </div>

              <div class="col-md-4">
                <div class="detail-item">
                  <label class="detail-label">Actualizado</label>
                  <div class="detail-value"><%= @event.updated_at.strftime("%d/%m/%Y %H:%M") %></div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="col-lg-4">
        <div class="card border-0 shadow-sm mb-4">
          <div class="card-header bg-white border-0 py-3">
            <h5 class="mb-0">
              <i class="fas fa-bolt text-warning me-2"></i>Acciones Rápidas
            </h5>
          </div>
          <div class="card-body">
            <div class="d-grid gap-2">
              <% if can?(:update, @event) %>
                <%= link_to edit_dashboard_event_path(@event), class: "btn btn-warning btn-lg" do %>
                  <i class="fas fa-edit me-2"></i>Editar Evento
                <% end %>
              <% end %>

              <% if can?(:create, Event) %>
                <%= link_to new_dashboard_event_path, class: "btn btn-outline-success" do %>
                  <i class="fas fa-plus me-2"></i>Nuevo Evento
                <% end %>
              <% end %>

              <%= link_to dashboard_events_path, class: "btn btn-outline-secondary" do %>
                <i class="fas fa-list me-2"></i>Ver Todos
              <% end %>
            </div>
          </div>
        </div>

        <% if can?(:destroy, @event) %>
          <div class="card border-0 shadow-sm border-danger mt-4">
            <div class="card-header bg-danger bg-opacity-10 border-0 py-3">
              <h5 class="mb-0 text-danger">
                <i class="fas fa-exclamation-triangle me-2"></i>Zona de Peligro
              </h5>
            </div>
            <div class="card-body">
              <p class="small text-muted mb-3">
                Esta acción eliminará el evento permanentemente.
              </p>
              <%= button_to dashboard_event_path(@event), method: :delete, data: { turbo_confirm: "¿Estás seguro de eliminar este evento?" }, class: "btn btn-outline-danger w-100" do %>
                <i class="fas fa-trash me-2"></i>Eliminar Evento
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>

<style>
.detail-item {
  margin-bottom: 1.5rem;
}

.detail-label {
  font-weight: 600;
  color: #6c757d;
  font-size: 0.875rem;
  margin-bottom: 0.5rem;
  display: block;
}

.detail-value {
  font-size: 1rem;
  color: #212529;
}

.btn-lg {
  padding: 0.875rem 1.5rem;
  font-size: 1rem;
}

.card {
  border-radius: 12px;
}

.card-header {
  border-bottom: 1px solid #f1f5f9;
}
</style>

<% content_for :title, @event.title.presence || "Evento" %>
