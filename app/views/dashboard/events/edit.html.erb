<%= render "layouts/header" %>
<div class="row">
  <%= render "layouts/sidebar" %>
  <div class="col-md mt-3 ms-auto col-lg-10 px-md-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <div>
        <h2 class="mb-1">
          <i class="fas fa-edit text-primary me-2"></i>Editar Evento
        </h2>
        <p class="text-muted mb-0">Modificar el evento: <%= @event.title.presence || "Sin título" %></p>
      </div>
    </div>

    <%= render "form", event: @event %>
  </div>
</div>

<% content_for :title, "Editar Evento" %>
