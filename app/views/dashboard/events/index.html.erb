<%= render "layouts/header" %>
<div class="row">
  <%= render "layouts/sidebar" %>
  <div class="col-md mt-3 ms-auto col-lg-10 px-md-4">
    <% if notice %>
      <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="fas fa-check-circle me-2"></i><%= notice %>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
      </div>
    <% end %>

    <% if alert %>
      <div class="alert alert-warning alert-dismissible fade show" role="alert">
        <i class="fas fa-exclamation-triangle me-2"></i><%= alert %>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
      </div>
    <% end %>

    <div class="d-flex justify-content-between align-items-center mb-4">
      <div>
        <h2 class="mb-1">
          <i class="fas fa-calendar-alt text-success me-2"></i>Eventos del Sistema
        </h2>
        <p class="text-muted mb-0">Administra los eventos institucionales de la DEU</p>
      </div>
      <% if can?(:create, Event) %>
        <%= link_to new_dashboard_event_path, class: "btn btn-green-deu" do %>
          <i class="fas fa-plus me-2"></i>Nuevo Evento
        <% end %>
      <% end %>
    </div>

    <div class="card border-0 shadow-sm">
      <div class="card-header bg-white border-0 py-3">
        <h5 class="mb-0">
          <i class="fas fa-list text-success me-2"></i>Lista de Eventos
        </h5>
      </div>

      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table table-hover mb-0">
            <thead class="table-light">
              <tr>
                <th scope="col" class="ps-4">N.</th>
                <th scope="col">Título</th>
                <th scope="col">Fecha</th>
                <th scope="col">Última actualización</th>
                <th scope="col" class="text-center">Acciones</th>
              </tr>
            </thead>
            <tbody>
              <% @events.each do |event| %>
                <tr>
                  <td class="ps-4">
                    <div class="event-icon bg-success-subtle text-success rounded me-3">
                      <%= event.id %>
                    </div>
                  </td>
                  <td>
                    <h6 class="mb-0 fw-bold"><%= event.title.presence || "Sin título" %></h6>
                  </td>
                  <td>
                    <small class="text-muted">
                      <%= event.day.present? ? l(event.day, format: "%A, %d de %B de %Y") : "Sin fecha" %>
                    </small>
                  </td>
                  <td>
                    <small class="text-muted"><%= event.updated_at.strftime("%d/%m/%Y %H:%M") %></small>
                  </td>
                  <td>
                    <div class="d-flex justify-content-center gap-2">
                      <%= link_to dashboard_event_path(event), class: "btn btn-sm btn-outline-success", title: "Ver" do %>
                        <i class="fas fa-eye"></i>
                      <% end %>
                      <% if can?(:update, event) %>
                        <%= link_to edit_dashboard_event_path(event), class: "btn btn-sm btn-outline-warning", title: "Editar" do %>
                          <i class="fas fa-edit"></i>
                        <% end %>
                      <% end %>
                      <% if can?(:destroy, event) %>
                        <%= button_to dashboard_event_path(event), method: :delete, data: { turbo_confirm: "¿Estás seguro de eliminar este evento?" }, form: { class: "d-inline" }, class: "btn btn-sm btn-outline-danger", title: "Eliminar" do %>
                          <i class="fas fa-trash"></i>
                        <% end %>
                      <% end %>
                    </div>
                  </td>
                </tr>
              <% end %>

              <% if @events.empty? %>
                <tr>
                  <td colspan="5" class="text-center py-5">
                    <div class="text-muted">
                      <i class="fas fa-calendar-times fa-3x mb-3"></i>
                      <h5>No hay eventos creados</h5>
                      <p class="mb-3">Comienza registrando el primer evento</p>
                      <% if can?(:create, Event) %>
                        <%= link_to new_dashboard_event_path, class: "btn btn-green-deu" do %>
                          <i class="fas fa-plus me-2"></i>Crear Evento
                        <% end %>
                      <% end %>
                    </div>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
.event-icon {
  width: 40px;
  height: 40px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-green-deu {
  background-color: #01695b;
  color: #ffffff;
}
</style>

<% content_for :title, "Eventos" %>
